guidebook.section.mob.undiscovered=Toj stvor ješče ne je otvoreny.
guidebook.section.mob.pig.name=Svinja
guidebook.section.mob.pig.desc=Svinje sut cěnny iztočnik jedy i često pojavjajut se v dikoj obsrědině.\nmožno najdti v večinstvu biomov.
guidebook.section.mob.sheep.name=Ovca
guidebook.section.mob.sheep.desc=Ovcy dajut volnu, imajuču mnogo priměnjenij.\nmožno najdti v večinstvu biomov.
guidebook.section.mob.cov.name=Krava
guidebook.section.mob.cov.desc=Kravy sut iztočnik koži, upotrěbjajuče se dlja stvorjenja bronje.\nmožno najdti v večinstvu biomov.
guidebook.section.mob.hicken.name=Kura
guidebook.section.mob.hicken.desc=Kury sut iztočnik per, upotrěbjajuče se dlja strěl.\nmožno najdti v večinstvu biomov.
guidebook.section.mob.skvid.name=Sprut
guidebook.section.mob.skvid.desc=Spruty sut iztočnik črnil, ktorymi možno farbovati volnu.\nmožno najdti v jezerah i okeanah.
guidebook.section.mob.volf.name=Volk
guidebook.section.mob.volf.desc=Volki sut pasivne moby, odomašnjajeme kostju.\nmožno najdti v hladnyh biomah, takih kak tajga i sněžne lěsy.
guidebook.section.mob.firefly_cluster.name=Světlušky
guidebook.section.mob.firefly_cluster.desc=Světlušky pojavjajut se kak zasvěčajuči oblak světla, ktoro možno izloviti v banku dlja stvorjenja světilky.\nmožno najdti v večinstvu biomov.
guidebook.section.mob.zombie.name=Zombi
guidebook.section.mob.zombie.desc=Zombi sut razprostranjeni protivniki, že pojavjajut se nočeju i vo tmě. Oni bijut bolěsno, tak že ostražno!
guidebook.section.mob.creeper.name=Kriper
guidebook.section.mob.creeper.desc=Kripery sut izvěstne stvory, že izbuhajut se, ako podojdut prěmnogo blizko. Pojavjajut se nočeju i vo tmě.
guidebook.section.mob.skeleton.name=Skelet
guidebook.section.mob.skeleton.desc=Skelety javjajut se opasnymi dalebojnymi pomočnikami dlja ostalyh stvorov. Sovětujemo najdti ukrytje. Pojavjajut se nočeju i vo tmě.
guidebook.section.mob.spider.name=Pavuk
guidebook.section.mob.spider.desc=Pavuki sut velike, bystre i mogut laziti po stěnam. Razprostranjeni protivniki, že pojavjajut se nočeju i vo tmě.
guidebook.section.mob.slime.name=Slimak
guidebook.section.mob.slime.desc=Slimaki pojavjajut se na samom dnu světa i mogut byti opasne v grupah. Sposobne razděljati se na slimakov pomenje.
guidebook.section.mob.ghast.name=Gast
guidebook.section.mob.ghast.desc=Gasty sut velike lětajuče stvory, strěljajuče ognjenymi kuljami v Vas. Možno najdti v Nezeru.
guidebook.section.mob.zombie_pigman.name=Svinozombi
guidebook.section.mob.zombie_pigman.desc=Svinozombi sut razprostranjene stvory v Nezeru. Oni sut neškodlive, ako ne provokovati.
guidebook.section.mob.snovman.name=Sněžny člověk
guidebook.section.mob.snovman.desc=Sněžne ljudi sut vid zombi, že pojavjajut se toliko v samyh hladnyh městah. Kydajut kaliny, da by zadržati napastnikov.
guidebook.section.mob.armored_zombie.name=Zombi v bronji
guidebook.section.mob.armored_zombie.desc=Veče smrtonosny variant zombi, oděty v koljčugu i rědko vladějuči mečom.

